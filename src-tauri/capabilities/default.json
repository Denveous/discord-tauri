  "identifier": "default",
  "description": "default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-open"
  ],
  "remote": {
    "urls": ["https://discord.com/*", "https://*.discord.com/*", "https://*.discordapp.com/*"]
  }
}
